# OpenAI
OPENAI_API_KEY=
AGENT_MODEL=

# Service URLs
AGENT_SERVICE_URL=http://localhost:8000
TOOL_SERVER_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000

# Internal tool authentication for local development
TOOL_SERVER_TOKEN=local-dev-token

# PostgreSQL owner credentials for local initialization.
# Set strong local-only values in .env. Never commit .env.
POSTGRES_DB=stacksleuth
POSTGRES_USER=stacksleuth_owner
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Read-only credentials used by the Spring tool server.
TOOL_DB_ENABLED=true
TOOL_DB_URL=jdbc:postgresql://localhost:5432/stacksleuth
TOOL_DB_USER=stacksleuth_reader
TOOL_DB_PASSWORD=

# Keeps the checked-in sample logs inside the demo's "recent" time window.
# Leave empty outside deterministic demo/replay runs.
TOOL_SERVER_CLOCK_INSTANT=2026-06-24T03:00:00Z

# Guardrail defaults
AGENT_MAX_ITERATIONS=5
TOOL_TIMEOUT_SECONDS=5
REQUEST_TIMEOUT_SECONDS=30
MAX_TOOL_OUTPUT_CHARS=8000
TRACE_DIRECTORY=../var/traces
SQL_MAX_ROWS=50
LOG_MAX_MATCHES=100

# Optional pricing metadata.
# Leave disabled until a checked-in pricing config exists.
ENABLE_COST_ESTIMATES=false
